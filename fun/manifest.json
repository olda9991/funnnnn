{
  "manifest_version": 3,
  "name": "Fun Extension",
  "version": "1.0.0",
  "description": "A fun and colorful browser extension",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.png"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}
